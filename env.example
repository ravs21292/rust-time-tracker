# Environment Configuration for Time Tracker (High Performance)

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/time_tracker

# Redis Configuration (for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# JWT Secret (Change in production!)
JWT_SECRET=your-secret-key-change-in-production

# Service Ports
AUTH_SERVICE_PORT=50051
ACTIVITY_SERVICE_PORT=50052
SCREENSHOT_SERVICE_PORT=50053
API_GATEWAY_PORT=8080

# Service URLs (for API Gateway)
AUTH_SERVICE_URL=http://localhost:50051
ACTIVITY_SERVICE_URL=http://localhost:50052
SCREENSHOT_SERVICE_URL=http://localhost:50053

# Screenshot Storage
SCREENSHOT_STORAGE_PATH=/tmp/screenshots
SCREENSHOT_COMPRESSION_QUALITY=80

# Performance Settings
MAX_REQUESTS_PER_MINUTE=1000
DB_MAX_CONNECTIONS=100
DB_MIN_CONNECTIONS=10
DB_ACQUIRE_TIMEOUT=30

# Logging
RUST_LOG=info
RUST_BACKTRACE=1

# Development Settings
DEVELOPMENT_MODE=true
HOT_RELOAD=true
